{
  "manifest_version": 3,
  "name": "ACC Connector",
  "version": "1.0.0",
  "description": "Intercepts acc-connect:// links and broadcasts server info via LAN discovery (UDP :8999) so ACC can find them.",

  "permissions": ["nativeMessaging", "storage"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ACC Connector"
  }
}
